# -------------------------------------------------------
# GeoNews Backend Environment Variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# Supabase project URL (Settings > API > Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (Settings > API > service_role secret)
# Keep this secret - never expose it to the browser
SUPABASE_SERVICE_KEY=your-service-role-key

# NewsAPI.org key (https://newsapi.org/register)
NEWS_API_KEY=your-newsapi-key

# Optional: override the default port (5001)
# PORT=5001
